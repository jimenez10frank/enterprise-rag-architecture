# Copy this file to .env and fill in your real keys. Never commit .env.

# --- LLM / Embeddings (OpenAI) ---
OPENAI_API_KEY=sk-...

# --- Reranker (Cohere) ---
COHERE_API_KEY=...

# --- Observability (optional but recommended) ---
LANGSMITH_API_KEY=...
LANGSMITH_PROJECT=legal-rag-nl

# --- Infrastructure ---
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379

# --- Cache config ---
# Must stay >= 0.97 for fiscal/legal data (see docs/project/TRAPS.md TRAP 5)
SEMANTIC_CACHE_THRESHOLD=0.97
SEMANTIC_CACHE_TTL_SECONDS=86400

# --- Corpus versioning (bump when new legislation is ingested) ---
CORPUS_VERSION=v1
